{%- set showPark = withoutPark == false and material.material.park.name is not empty -%}
{%- set showLocation = material.material.parkLocation.label is not empty -%}
{%- set showProperties = (
    material.material.properties is not empty or
    material.material.weight is not empty or
    material.material.origin_country is not empty
) -%}
<tr>
    {% if showPictures -%}
    <td class="picture-cell">
        <img
            src="{{ material.material.picture ?: asset('/img/material-picture-placeholder.png', true) }}"
            class="material-picture"
        />
    </td>
    {% endif -%}
    <td>{{ material.reference }}</td>
    <td>
        {{- material.name }}
        {%- if showPark or showLocation -%}
            {%-
                set location = (
                    (showPark ? material.material.park.name : '') ~
                    ((showPark and showLocation) ? ': ' : '') ~
                    (showLocation ? material.material.parkLocation.label : '')
                )
            -%}
            {{- ' ' -}}
            <em class="lighter">({{ location }})</em>
        {%- endif -%}
        {%- if showProperties -%}
            <br />
            {% if material.material.weight is not empty -%}
            <span class="lighter">
                {{- __('weight-value', [
                    material.material.weight|format_number(locale=locale),
                    measurementUnits.materials.weight,
                ]) -}}
            </span>
            {% endif -%}
            {% if material.material.origin_country is not empty -%}
            <span class="lighter">
                {{- __('origin-country-value', [material.material.origin_country.getName(locale)]) -}}
            </span>
            {% endif -%}
            {%- for property in material.material.properties -%}
                {{ include('blocks/materials/property.twig', { property }) -}}
            {%- endfor -%}
        {%- endif -%}
    </td>
    {% if showDescriptions -%}
    <td class="max50mm">
        {{- material.material.description|nl2br -}}
    </td>
    {% endif -%}
    {% if showTags -%}
    <td class="center">
        {%- for tag in material.material.tags -%}
        {{ tag.name }}<br />
        {%- endfor -%}
    </td>
    {% endif -%}
    {% if showReplacementPrices -%}
    <td class="right lighter">
        {{- (material.unit_replacement_price ?? 0)|format_currency(event.currency, locale=locale) -}}
    </td>
    <td class="right lighter">
        {{- (material.total_replacement_price ?? 0)|format_currency(event.currency, locale=locale) -}}
    </td>
    {% endif -%}
    <td class="center">
        {{- material.quantity -}}
    </td>
    <td class="center"></td>
</tr>
