<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <title>{% block title %}{% endblock %}</title>
    <meta name="generator" content="Loxya" />

    <style type="text/css">
        embedded-xml {
            display: block;
            margin: 30px;
            padding: 15px;
            background: #1e1e2e;
            border-radius: 10px;
            color:#cdd6f4;
            line-height: 1.6;
            font-size: 14px;
            font-family: monospace;
            white-space: pre;
            overflow-x: auto;
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
    {% block running %}{% endblock %}
    {% block content %}{% endblock %}
</body>
</html>